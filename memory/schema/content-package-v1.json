{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes.lermf.org/schemas/content-package-v1.json",
  "title": "Hermes→UniTeia Content Package Contract v1",
  "type": "object",
  "required": ["package_id", "timestamp", "source", "posts"],
  "properties": {
    "package_id": {
      "type": "string",
      "pattern": "^pkg-[0-9]{8}-[0-9]{6}-[a-z0-9]{8}$",
      "description": "Unique package identifier: pkg-YYYYMMDD-HHMMSS-hash8"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of package generation"
    },
    "source": {
      "type": "object",
      "required": ["agent", "version", "pipeline"],
      "properties": {
        "agent": { "type": "string", "enum": ["hermes-daily-ops", "hermes-scout", "hermes-writer"] },
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "pipeline": { "type": "string", "enum": ["daily", "batch", "test"] }
      }
    },
    "posts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["post_id", "slug", "title", "content", "lang", "category"],
        "properties": {
          "post_id": { "type": "string", "pattern": "^post-[0-9]{14}-[a-z0-9]{6}$" },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 100 },
          "title": { "type": "string", "minLength": 10, "maxLength": 200 },
          "content": { "type": "string", "minLength": 100, "maxLength": 50000 },
          "lang": { "type": "string", "enum": ["pt", "en", "es", "fr", "de", "it", "ja", "zh"] },
          "category": { "type": "string", "enum": ["tecnologia", "negocios", "ciencia", "arte", "default"] },
          "meta": {
            "type": "object",
            "properties": {
              "author": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
              "reading_time_min": { "type": "integer", "minimum": 1, "maximum": 60 },
              "eval_d9": { "type": "number", "minimum": 0, "maximum": 1 },
              "image_manifest": {
                "type": "array",
                "maxItems": 4,
                "items": {
                  "type": "object",
                  "properties": {
                    "role": { "type": "string", "enum": ["hero", "inline_1", "inline_2", "footer"] },
                    "preset": { "type": "string", "enum": ["body_editorial", "body_conceptual", "body_portrait", "footer_banner"] },
                    "url": { "type": "string", "format": "uri" },
                    "local_path": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "object",
        "required": ["asset_id", "type", "url", "alt"],
        "properties": {
          "asset_id": { "type": "string" },
          "type": { "type": "string", "enum": ["image", "video", "audio"] },
          "url": { "type": "string", "format": "uri" },
          "alt": { "type": "string", "maxLength": 200 },
          "dimensions": {
            "type": "object",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
