{
  "name": "uniteia-v2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.6",
  "description": "UniTeia v2 - Qwik-City site with multilingual content",
  "type": "module",
  "scripts": {
    "generate:content-registry": "bun run scripts/generate-content-registry.ts && bun run lint.fix",
    "generate:content-graph": "bun run scripts/generate-content-graph.ts && bun run lint.fix",
    "generate:linkgraph-report": "bun run scripts/generate-linkgraph-report.ts",
    "generate:seo-verification": "bun run scripts/generate-seo-verification.ts",
    "verify:content-graph": "bun run scripts/verify-content-graph.ts",
    "generate:search-index": "bun run scripts/generate-search-index.ts",
    "generate:content": "bun run generate:content-registry && bun run generate:content-graph && bun run verify:content-graph && bun run generate:search-index",
    "dev": "vite --mode ssr",
    "edge:chaos": "bun run scripts/edge-chaos-test.ts",
    "cloudflare:purge": "bun run scripts/cloudflare-purge.ts",
    "build": "bun run generate:content && qwik build",
    "build.preview": "wrangler pages dev dist --compatibility-date=2026-04-01 --compatibility-flags nodejs_compat --port=8788",
    "build.client": "vite build",
    "build.ssr": "vite build --ssr src/entry.ssr.tsx",
    "build.server": "vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build:watch": "qwik build --watch",
    "preview": "qwik preview",
    "preview:cf": "wrangler pages dev dist --compatibility-date=2026-04-01 --compatibility-flags nodejs_compat --port=8788",
    "preview:multi": "concurrently -k \"bun run build:watch\" \"bun run preview:cf\" \"caddy run --config ./Caddyfile\"",
    "lint": "biome check .",
    "lint.fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "browser:verify": "playwright test tests/e2e/smoke.spec.ts tests/e2e/s05-shell-visual.spec.ts",
    "slug:check": "bun run scripts/slug-lint.ts",
    "content:check": "bun run scripts/validate-content.ts \"content/**/*.md\"",
    "size:check": "bun run scripts/size-gate.ts",
    "lighthouse:check": "bun run scripts/lighthouse-gate.ts --audit-path /en/signals/",
    "ship:check": "bun run scripts/ship-check.ts",
    "header:check": "bun run scripts/check-single-header.ts",
    "smoke:check": "bun run scripts/smoke-test.ts",
    "prepare:cloudflare-pages": "bun run scripts/prepare-cloudflare-pages-output.ts",
    "postbuild": "bun run scripts/generate-sitemap.ts && bun run scripts/build-service-worker.ts && bun run prepare:cloudflare-pages",
    "import:package": "bun run scripts/import-content-package.ts"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@uniteia/content-node-contract": "file:../uniteia-mega-factory/packages/content-node-contract",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.10.0",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "4.20260518.1",
    "@iconify-json/lucide": "1.2.108",
    "@iconify/tailwind": "^1.2.0",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "ajv": "8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.5.0",
    "postcss-custom-media": "^11.0.5",
    "postcss-nesting": "^12.1.5",
    "postcss-preset-env": "^10.1.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^6.2.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "4.1.6",
    "wrangler": "4.92.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
