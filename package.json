{
  "name": "uniteia-v2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.6",
  "description": "UniTeia v2 - Qwik-City site with multilingual content",
  "type": "module",
  "scripts": {
    "dev": "vite --mode ssr",
    "build": "qwik build",
    "build.preview": "wrangler pages dev dist --script-path server/entry.cloudflare-pages.js --no-bundle --compatibility-date=2026-04-01 --port=8788",
    "build.client": "vite build",
    "build.ssr": "vite build --ssr src/entry.ssr.tsx",
    "build.server": "vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build:watch": "qwik build --watch",
    "preview": "qwik preview",
    "preview:cf": "wrangler pages dev dist --script-path server/entry.cloudflare-pages.js --no-bundle --compatibility-date=2026-04-01 --port=8788",
    "preview:multi": "concurrently -k \"bun run build:watch\" \"bun run preview:cf\" \"caddy run --config ./Caddyfile\"",
    "lint": "biome check .",
    "lint.fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "browser:verify": "playwright test tests/e2e/smoke.spec.ts tests/e2e/s05-shell-visual.spec.ts",
    "slug:check": "bun run scripts/slug-lint.ts",
    "size:check": "bun run scripts/size-gate.ts",
    "lighthouse:check": "bun run scripts/lighthouse-gate.ts",
    "ship:check": "bun run scripts/ship-check.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250409.0",
    "@iconify-json/lucide": "^1.2.103",
    "@iconify/tailwind": "^1.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.5.0",
    "lighthouse": "^13.1.0",
    "postcss": "^8.5.10",
    "postcss-custom-media": "^11.0.5",
    "postcss-nesting": "^12.1.5",
    "postcss-preset-env": "^10.1.5",
    "tailwindcss": "^3",
    "typescript": "~5.6.2",
    "vite": "^6.2.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@modular-forms/qwik": "^0.24.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
