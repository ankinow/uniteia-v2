{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "runs",
      "llm-wiki-uniteia",
      "content/**/*.json",
      "_engine/tests/golden/**"
    ]
  },
  "linter": { "enabled": true, "rules": { "recommended": true } },
  "formatter": { "enabled": true, "indentStyle": "tab", "lineWidth": 100 },
  "organizeImports": { "enabled": true }
}
