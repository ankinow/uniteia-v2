  "contentPipeline": {
    "steps": [
      {
        "order": 1,
        "name": "Vite Glob",
        "mechanism": "import.meta.glob('../../content/**/*.md', { query: '?raw', import: 'default', eager: true })",
        "purpose": "Bundle all markdown at build-time (no node:fs at edge)"
      },
      {
        "order": 2,
        "name": "gray-matter",
        "config": { "engines": { "js": "() => { throw new Error('JS eval disabled') }" } },
        "purpose": "Parse YAML frontmatter; JS eval explicitly disabled"
      },
      {
        "order": 3,
        "name": "marked",
        "config": { "async": false, "breaks": false, "gfm": true, "stripH1": true },
        "purpose": "Server-side MD→HTML (GFM); H1 headings stripped"
      },
      {
        "order": 4,
        "name": "DOMPurify",
        "library": "isomorphic-dompurify@3.10.0",
        "purpose": "XSS prevention — strips <script>, onclick, etc."
      },
      {
        "order": 5,
        "name": "AJV Schema",
        "schema": "schemas/llm-wiki-v1.schema.json",
        "draft": "2020-12",
        "purpose": "Validate frontmatter against strict JSON Schema"
      },
      {
        "order": 6,
        "name": "Slug Validation",
        "pattern": "^[a-z]+(-[a-z]+){1,5}$",
        "purpose": "Enforce URL-safe slugs, ban reserved/problematic terms"
      },
      {
        "order": 7,
        "name": "LlmWikiContent",
        "purpose": "Typed output object delivered to route loader"
      },
      {
        "order": 8,
        "name": "ArticleFrame",
        "purpose": "Qwik component renders the content in brutalist container"
      }
    ],
    "errorPhases": ["read", "parse", "schema", "slug"],
    "errorClass": "ContentLoaderError"
  },
  "contentSchema": {
    "$id": "https://uniteia.com/schemas/llm-wiki-v1.schema.json",
    "draft": "2020-12",
    "additionalProperties": false,
    "required": ["slug", "lang", "title", "content", "subjects", "referral_links"],
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[a-z]+(-[a-z]+){1,5}$",
        "description": "URL slug with 2-6 hyphenated segments"
      },
      "lang": { "type": "string", "enum": ["en", "pt", "es", "ja", "zh"] },
      "title": { "type": "string", "minLength": 1, "maxLength": 200 },
      "content": { "type": "string", "minLength": 100 },
      "subjects": {
        "type": "array",
        "items": { "type": "string", "minLength": 1, "maxLength": 50 },
        "minItems": 1,
        "maxItems": 10
      },
      "referral_links": {
        "type": "array",
        "maxItems": 5,
        "items": {
          "required": ["url", "title"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "title": { "type": "string", "minLength": 1, "maxLength": 100 },
            "description": { "type": "string", "maxLength": 200 }
          }
        }
      },
      "verdict": {
        "type": "string",
        "enum": ["trusted", "caution", "flagged"],
        "default": "trusted"
      },
      "quality_score": { "type": "integer", "minimum": 0, "maximum": 100, "default": 85 },
      "metadata": {
        "type": "object",
        "properties": {
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "author": { "type": "string", "maxLength": 100 },
          "version": { "type": "integer", "minimum": 1 }
        }
      }
    }
  },
