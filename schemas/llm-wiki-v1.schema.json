{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uniteia.com/schemas/llm-wiki-v1.schema.json",
  "title": "LLM Wiki Content v1",
  "description": "Schema for LLM-generated wiki content with multilingual support",
  "type": "object",
  "required": ["slug", "lang", "title", "content", "subjects", "referral_links"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["article", "index"],
      "description": "Content type — article (default) or index (landing page)",
      "default": "article"
    },
    "slug": {
      "type": "string",
      "pattern": "^(_index|[a-z]+(-[a-z]+){1,5})$",
      "description": "URL slug with 2-6 hyphenated segments, lowercase letters only, or '_index' for landing pages",
      "examples": ["_index", "solar-system", "artificial-intelligence", "climate-change-causes"]
    },
    "lang": {
      "type": "string",
      "enum": ["en", "pt", "es", "ja", "zh"],
      "description": "ISO 639-1 language code matching SupportedLanguage type"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "content": {
      "type": "string",
      "minLength": 100,
      "description": "Main article content in markdown format"
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "minItems": 1,
      "maxItems": 10,
      "description": "Subject tags for categorization"
    },
    "referral_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "External reference URL"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Link title"
          },
          "description": {
            "type": "string",
            "maxLength": 200,
            "description": "Optional link description"
          }
        }
      },
      "maxItems": 5,
      "description": "External reference links, maximum 5 per article"
    },
    "verdict": {
      "type": "string",
      "enum": ["trusted", "caution", "flagged"],
      "description": "Editorial verdict level — trusted, caution, or flagged",
      "default": "trusted"
    },
    "quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Editorial quality score 0-100 (0-39=flagged, 40-69=caution, 70-100=trusted)",
      "default": 85
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string",
          "maxLength": 100
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "canvas": {
      "type": "object",
      "description": "SceneGraph definition for Aether Canvas rendering",
      "required": ["version", "tone", "nodes", "connectors"],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "SceneGraph schema version"
        },
        "tone": {
          "type": "string",
          "enum": ["obsidian", "parchment", "warm-gray"],
          "description": "Canvas visual tone"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "section", "x", "y", "width", "height", "type"],
            "properties": {
              "id": { "type": "string" },
              "section": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "type": {
                "type": "string",
                "enum": ["card", "hero", "image-cluster", "connector-label"]
              },
              "variant": { "type": "string" },
              "zIndex": { "type": "integer" }
            }
          }
        },
        "connectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "from", "to"],
            "properties": {
              "id": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" },
              "type": { "type": "string", "enum": ["solid", "dashed", "glow", "ink"] },
              "label": { "type": "string" }
            }
          }
        },
        "style": {
          "type": "string",
          "enum": [
            "constellation",
            "neural-branch",
            "timeline-spiral",
            "editorial-collage",
            "corkboard-scatter",
            "masonry-constellation"
          ]
        }
      }
    }
  }
}
