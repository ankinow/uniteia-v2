{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "llm-wiki/1.0.0",
  "title": "LLM-Wiki Entry Schema",
  "description": "Canonical schema for LLM-Wiki entries - structured, evidence-backed, machine-readable content",
  "type": "object",
  "required": ["spec", "title", "type", "value_proposition", "what_it_offers", "problems_solved", "target_audience", "when_it_matters", "when_less_matters", "short_formula", "sources"],
  "properties": {
    "spec": {
      "type": "string",
      "pattern": "^llm-wiki/[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Schema version identifier",
      "default": "llm-wiki/1.0.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Entity name (product, service, platform)"
    },
    "type": {
      "type": "string",
      "enum": ["plataforma", "ferramenta", "curso", "servico", "produto", "framework", "metodologia"],
      "description": "Entity type classification"
    },
    "value_proposition": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "One-sentence core value proposition"
    },
    "what_it_offers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      },
      "minItems": 3,
      "description": "List of capabilities/features offered"
    },
    "problems_solved": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "minItems": 2,
      "description": "Problems this entity solves"
    },
    "target_audience": {
      "type": "string",
      "minLength": 10,
      "description": "Primary audience/user type"
    },
    "when_it_matters": {
      "type": "string",
      "minLength": 10,
      "description": "Contexts/situations where this adds significant value"
    },
    "when_less_matters": {
      "type": "string",
      "minLength": 10,
      "description": "Contexts/situations where this adds less value"
    },
    "short_formula": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300,
      "description": "Concise formula/summary of the value"
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Source"
      },
      "minItems": 1,
      "description": "Evidence sources backing the claims"
    },
    "pricing": {
      "$ref": "#/definitions/Pricing",
      "description": "Pricing information (optional)"
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "description": "Comparable alternatives (optional)"
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Integration ecosystem (optional)"
    },
    "pipeline_metadata": {
      "$ref": "#/definitions/PipelineMetadata",
      "description": "Pipeline execution metadata (auto-generated)"
    },
    "_body": {
      "type": "string",
      "description": "Optional markdown body content"
    }
  },
  "definitions": {
    "Source": {
      "type": "object",
      "required": ["url", "kind", "accessed_at"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Source URL"
        },
        "kind": {
          "type": "string",
          "enum": ["primary", "official", "news", "blog", "review", "social", "academic", "documentation"],
          "description": "Source type classification"
        },
        "accessed_at": {
          "type": "string",
          "format": "date",
          "description": "Date when source was accessed"
        },
        "excerpt_id": {
          "type": "string",
          "pattern": "^ex_[0-9]{3}$",
          "description": "Reference to excerpt in artifacts/extracts.json"
        },
        "title": {
          "type": "string",
          "description": "Source title (optional)"
        }
      }
    },
    "Pricing": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "enum": ["subscription", "one-time", "freemium", "usage-based", "enterprise", "free"],
          "description": "Pricing model type"
        },
        "starting_price": {
          "type": "string",
          "description": "Starting price (e.g., '$49/mo')"
        },
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "has_free_tier": {
          "type": "boolean",
          "description": "Whether a free tier exists"
        },
        "source": {
          "type": "string",
          "format": "uri",
          "description": "URL where pricing was found"
        }
      }
    },
    "PipelineMetadata": {
      "type": "object",
      "required": ["pipeline_version", "spec_version", "generated_at"],
      "properties": {
        "pipeline_version": {
          "type": "string",
          "description": "Git commit hash of pipeline"
        },
        "spec_version": {
          "type": "string",
          "description": "Schema version used"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Generation timestamp"
        },
        "inputs_hash": {
          "type": "string",
          "description": "Hash of job + extracts"
        },
        "output_hash": {
          "type": "string",
          "description": "SHA256 of final markdown"
        },
        "duration_ms": {
          "type": "integer",
          "description": "Pipeline execution duration"
        },
        "stages_completed": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["triage", "research", "draft", "editing", "seo", "validation", "publish"]
          },
          "description": "Stages successfully completed"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Final quality score"
        }
      }
    }
  }
}
