{
  "name": "orquidia-uniteia",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "tools/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "guardian": "bun run --cwd tools/guardian check",
    "guardian:agents": "bun run --cwd tools/guardian validate",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.7.5",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  },
  "packageManager": "bun@1.3.6"
}
