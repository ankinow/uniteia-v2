{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "./src/types/cloudflare-shim"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@orquestra/shared": ["../../packages/shared/src"],
      "@orquestra/ai-core": ["../../packages/ai-core/src"],
      "@orquestra/ai-core/economic": ["../../packages/ai-core/src/index-economic.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    ".output",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
