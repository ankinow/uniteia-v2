{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@orquestra/shared": ["./packages/shared/src"],
      "@orquestra/ai-core": ["./packages/ai-core/src"],
      "@orquestra/ai-core/economic": ["./packages/ai-core/src/index-economic.ts"],
      "@orquestra/db": ["./packages/db/src"],
      "@orquestra/moneyprinter": ["./packages/moneyprinter/src"],
      "@orquestra/moneyprinter/*": ["./packages/moneyprinter/src/*"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "tools",
    "node_modules",
    "dist",
    ".output",
    ".turbo",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/scripts/**",
    "**/test-integration.ts",
    "packages/shared/src/types/cloudflare.ts"
  ]
}
