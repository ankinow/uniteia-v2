# =============================================================================
# ORQUIDIA-UNITEIA ENVIRONMENT VARIABLES - SOTA 2026
# =============================================================================
# Copy this file to .env and fill in the values
# SENSITIVE DATA: Use `wrangler secret put <KEY>` for production!

# =============================================================================
# WORKERS AI (PRIMARY - FREE TIER)
# =============================================================================
# Provider Priority:
#   1. Workers AI @cf/meta/llama-3.1-8b-instruct-fp8-fast (PRIMARY)
#   2. Workers AI @cf/meta/llama-3.3-70b-instruct-fp8-fast (COMPLEX)
#   3. Gemini 2.0 Flash (FALLBACK)
#
# Workers AI is FREE on Workers Free tier for 10K requests/day

# Cloudflare Account ID (NOT a secret)
CLOUDFLARE_ACCOUNT_ID=your_account_id

# API Token (set via: npx wrangler secret put CLOUDFLARE_API_TOKEN)
CLOUDFLARE_API_TOKEN=

# =============================================================================
# AI MODELS CONFIGURATION
# =============================================================================
WORKERS_AI_MODEL_PRIMARY=@cf/meta/llama-3.1-8b-instruct-fp8-fast
WORKERS_AI_MODEL_COMPLEX=@cf/meta/llama-3.3-70b-instruct-fp8-fast
WORKERS_AI_EMBEDDING_MODEL=@cf/baai/bge-m3
WORKERS_AI_MODEL_FALLBACK=@cf/meta/llama-2-7b-chat-int8

# =============================================================================
# GEMINI API (FALLBACK)
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# CONTENT GENERATION CONFIG
# =============================================================================
CONTENT_LANGUAGE=pt-BR
CONTENT_REGION=BR
DEFAULT_TONE=professional
MIN_TOKENS_PER_PAGE=2500
MAX_TOKENS_PER_PAGE=4000
MIN_PRODUCTS_PER_PAGE=5
MAX_PRODUCTS_PER_PAGE=12

# =============================================================================
# AFFILIATE & MONETIZATION
# =============================================================================
# Affiliate programs configured
AFFILIATE_MERCADO_LIVRE=true
AFFILIATE_AMAZON=true
AFFILIATE_SHOPEE=true
AFFILIATE_HOTMART=true
AFFILIATE_MONETIZZE=true

# =============================================================================
# DATABASE (D1)
# =============================================================================
D1_DATABASE_ID=your_database_id
D1_DATABASE_NAME=uniteia-db
DB_BINDING_NAME=DB

# =============================================================================
# QDRANT (Vector Search - Optional)
# =============================================================================
QDRANT_URL=https://kilo-t0qdg6.qdrant.io
QDRANT_API_KEY=

# =============================================================================
# SEO CONFIG
# =============================================================================
SITE_URL=https://uniteia.com
SITE_NAME=Uniteia
DEFAULT_AUTHOR=Equipe Uniteia
DEFAULT_LANGUAGE=pt-BR
SCHEMA_ORG_VERSION=1.0.0
SCHEMA_ORG_CONTEXT=https://schema.org

# =============================================================================
# CLOUDFLARE ACCESS
# =============================================================================
CF_ACCESS_TEAM_NAME=
CF_ACCESS_AUD=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# =============================================================================
# RATE LIMITS
# =============================================================================
RATE_LIMIT_REQUESTS_PER_DAY=100
RATE_LIMIT_PAGES_PER_DAY=50
RATE_LIMIT_TOKENS_PER_DAY=1000000

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# MONITORING
# =============================================================================
DATADOG_API_KEY=
SENTRY_DSN=

# =============================================================================
# CACHE
# =============================================================================
CACHE_CONTROL_MAX_AGE=86400
STALE_WHILE_REVALIDATE=60

# =============================================================================
# INTERNAL SERVICES
# =============================================================================
HYPERBROWSER_API_KEY=
