{
  "name": "@orquestra/ai-core",
  "version": "0.2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agents": "./src/agents/index.ts",
    "./providers": "./src/providers/index.ts",
    "./rust": "./src/rust/index.ts",
    "./a2a": "./src/a2a/index.ts",
    "./economic": "./src/index-economic.ts"
  },
  "scripts": {
    "build:rust": "cd src/rust && cargo build --release --target wasm32-unknown-unknown",
    "build:ts": "tsc",
    "build": "bun run build:rust && bun run build:ts",
    "test": "bun run scripts/test.ts",
    "start:a2a": "bun run build && bun run src/a2a/server.ts",
    "start:a2a:prod": "node build/a2a/server.js"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^2.1.14",
    "@langchain/langgraph": "^1.1.3",
    "@langchain/langgraph-sdk": "^0.1.0",
    "@langchain/openai": "^1.2.4",
    "@orquestra/shared": "workspace:*",
    "langchain": "^0.3.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "wasm-pack": "^0.13.0"
  }
}
